  "keyFeatures": [
    "Firebase Authentication with login, registration, and password recovery",
    "Speech-to-text with Spanish language normalization for email and password dictation",
    "CRUD operations for phrase management with Firestore",
    "Geolocation with reverse geocoding to convert coordinates to addresses",
    "Text-to-speech synthesis with Spanish (Chile) locale",
    "Material Design 3 UI with dark/light theme support",
    "Service-Repository architecture pattern for clean separation of concerns"
  ],
  "publicApiSurface": [
    "HomeScreen - Main UI with phrase CRUD and navigation",
    "LoginScreen - Authentication UI for user login",
    "RegisterScreen - User registration with voice input support",
    "DeviceLocationScreen - Geolocation display with address",
    "AuthService - Authentication facade (login, register, logout)",
    "PhraseService - Phrase CRUD operations",
    "LocationService - Device location with reverse geocoding",
    "SpeechController - Speech recognition controller",
    "TextToSpeechController - TTS synthesis controller",
    "AuthRepository - Firebase Auth integration",
    "PhraseRepository - Firestore phrase storage",
    "LocationRepository - FusedLocationProvider wrapper",
    "normalizeEmailFromSpeech() - Spanish speech normalization for emails",
    "normalizePasswordFromSpeech() - Spanish speech normalization for passwords",
    "AppUser - User domain model",
    "Phrase - Phrase domain model with timestamp",
    "DeviceLocation - Location coordinates model"
  ]
}
